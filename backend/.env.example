# ===== Banco (Supabase — Session Pooler / IPv4, porta 5432) =====
DATABASE_URL=postgresql+asyncpg://postgres.SEU_PROJETO:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# ===== Redis (opcional — sem ele, o rate limit usa memória) =====
# REDIS_URL=redis://default:senha@host:6379

# ===== Asaas (gateway) =====
# Crie uma conta e pegue a chave em: Configurações > Integrações > API
ASAAS_API_KEY=
# Sandbox: https://sandbox.asaas.com/api/v3  |  Produção: https://api.asaas.com/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Token que você define no painel do Asaas (Webhooks) e que ele reenvia no header
ASAAS_WEBHOOK_TOKEN=

# ===== Criptografia de PII (LGPD) — GERE valores próprios e NUNCA commite =====
# Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# HMAC: python -c "import secrets; print(secrets.token_urlsafe(32))"
DOC_HASH_KEY=

# ===== App =====
APP_ENV=development
APP_PORT=8080
FRONTEND_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
