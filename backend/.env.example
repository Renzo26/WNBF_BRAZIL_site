# ===== Banco (Supabase — Session Pooler / IPv4, porta 5432) =====
DATABASE_URL=postgresql+asyncpg://postgres.SEU_PROJETO:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# ===== Redis (opcional — sem ele, o rate limit usa memória) =====
# REDIS_URL=redis://default:senha@host:6379

# ===== Asaas (gateway) =====
# Crie uma conta e pegue a chave em: Configurações > Integrações > API
ASAAS_API_KEY=
# Sandbox: https://sandbox.asaas.com/api/v3  |  Produção: https://api.asaas.com/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Token que você define no painel do Asaas (Webhooks) e que ele reenvia no header
ASAAS_WEBHOOK_TOKEN=

# ===== Simulação (true = marca pago na hora, sem Asaas, e dispara o n8n) =====
SIMULATE_PAYMENT=false
N8N_CONFIRM_WEBHOOK_URL=

# ===== Meta Ads: Conversions API (mede Purchase também no Pix) =====
# Mesmo ID do pixel usado no front (index.html). Só muda se trocar de pixel.
META_PIXEL_ID=2079486772606007
# Events Manager > Pixel > Configurações > API de Conversões > Gerar token.
# Vazio = desativado. NUNCA commitar o valor real — só no painel do EasyPanel.
META_CAPI_TOKEN=

# ===== Criptografia de PII (LGPD) — GERE valores próprios e NUNCA commite =====
# Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# HMAC: python -c "import secrets; print(secrets.token_urlsafe(32))"
DOC_HASH_KEY=

# ===== Ingresso / credenciamento (staff) =====
# Chave HMAC que assina o QR do ingresso (se vazio, usa DOC_HASH_KEY)
# python -c "import secrets; print(secrets.token_urlsafe(32))"
TICKET_SIGN_KEY=
# Segredo do JWT do app de credenciamento (se vazio, usa DOC_HASH_KEY)
JWT_SECRET=
JWT_EXPIRE_MINUTES=720
# 1º usuário admin criado automaticamente no start (deixe em branco p/ não criar)
STAFF_SEED_USERNAME=admin
STAFF_SEED_PASSWORD=
STAFF_SEED_NAME=Administrador

# ===== App =====
APP_ENV=development
APP_PORT=8080
FRONTEND_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
